# ============ API CONFIG (src/lib/api.ts) ============

# Listings - set for live data (default: /api/listings → Vercel proxy)
VITE_LISTINGS_URL=
# Optional: extra query for local /api/listings (parameter names depend on Ruuster—ask them for sort/limit keys).
# VITE_LISTINGS_QUERY=limit=200
# How often to refetch listings on the home page when tab is visible (ms, min 10000). Default 45000.
# VITE_LISTINGS_POLL_MS=45000
# Or base URL: VITE_API_BASE=https://yoursite.com

# Leads - Formspree or custom
VITE_FORMSPREE_ID=
VITE_LEADS_ENDPOINT=

# ============ VERCEL (api/listings.ts) ============
# Set in Vercel dashboard for production:
#
# Base URL (default already points to Red Post's Ruuster tenant):
# RUUSTER_API_URL=https://redpostrealty.ruuster.com/api
#
# REQUIRED: agent slug scopes the public endpoint — no API key needed.
# Confirmed via GET /api/listings?slug=sarah-hudson&status=Active&limit=500 → 200 OK (66 records).
# Adjust `limit` to taste; `status=Active` is forced by the proxy. Other valid keys from
# Ruuster's basedFilterOptions: sortBy (newest|priceHL|priceLH|bedsHL|sqftHL|lotSizeHL|bathHL|priceReduced|oldest).
RUUSTER_LISTINGS_EXTRA_PARAMS=slug=sarah-hudson&limit=500&sortBy=newest
#
# Optional: only set if Ruuster ever adds an authenticated endpoint for this tenant.
# RUUSTER_API_KEY=
