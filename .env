# Committed defaults (site may be hosted off Vercel). Put secrets / machine-specific overrides in .env.local (gitignored via *.local).
#
# Browser loads listings from VITE_LISTINGS_URL. Your host must implement the same behavior as api/listings.ts:
# GET → Ruuster {RUUSTER_API_URL}/listings?status=Active& + RUUSTER_LISTINGS_EXTRA_PARAMS (Ruuster returns 401 without slug).
#
RUUSTER_LISTINGS_EXTRA_PARAMS=slug=sarah-hudson&limit=500&sortBy=newest
VITE_LISTINGS_URL=/api/listings
# Fastest allowed poll interval (see src/lib/api.ts — min 10000 ms).
VITE_LISTINGS_POLL_MS=10000
#
# Uncomment on the server that runs your listings proxy (if not using Vercel defaults):
# RUUSTER_API_URL=https://redpostrealty.ruuster.com/api
#
# Phone + chat (see .env.example). Set VITE_PHONE_TEL so “Call us” links work.
# VITE_PHONE_TEL=
# VITE_PHONE_DISPLAY=
# VITE_CHAT_URL=
